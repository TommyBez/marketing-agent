{
  "env": {
    "HOME": "/",
    "PATH": "/usr/bin:/bin",
    "IFS": " \t\n",
    "OSTYPE": "linux-gnu",
    "MACHTYPE": "x86_64-pc-linux-gnu",
    "HOSTTYPE": "x86_64",
    "HOSTNAME": "localhost",
    "PWD": "/workspace",
    "OLDPWD": "/workspace",
    "OPTIND": "1",
    "SHELLOPTS": "braceexpand:hashall:interactive-comments",
    "BASHOPTS": "globskipdots"
  },
  "version": 1
}
